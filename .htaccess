# ── Cache long terme pour les assets versionnés (bundle + CSS minifiés) ──
<IfModule mod_expires.c>
  ExpiresActive On
  # Bundles minifiés : 1 an (nom de fichier à changer à chaque build pour invalider)
  ExpiresByType application/javascript "access plus 1 year"
  ExpiresByType text/css              "access plus 1 year"
  # Polices
  ExpiresByType font/truetype         "access plus 1 year"
  ExpiresByType font/woff2            "access plus 1 year"
  # HTML : pas de cache (toujours frais)
  ExpiresByType text/html             "access plus 0 seconds"
</IfModule>

<IfModule mod_headers.c>
  # Cache-Control explicite sur les bundles
  <FilesMatch "\.(min\.js|min\.css)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>
  # Pas de cache sur le HTML
  <FilesMatch "\.html$">
    Header set Cache-Control "no-cache, must-revalidate"
  </FilesMatch>
  # Preload : le navigateur découvre style.min.css dès la réponse HTML
  # sans attendre de parser le <link>
  <FilesMatch "\.html$">
    Header add Link "</dist/style.min.css>; rel=preload; as=style"
  </FilesMatch>
</IfModule>

# ── Compression ──
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/css application/javascript
</IfModule>
